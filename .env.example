# Copy this file to .env.local and fill in your own values.
# See supabase/README.md for how to get these.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PUBLIC_APP_URL=https://bonado-sage.vercel.app

# Google Cloud Console: enable "Places API (New)" + link billing, then
# create an API key (Places API (New) restriction recommended).
VITE_GOOGLE_PLACES_API_KEY=

# unsplash.com/developers: create an app, use its Access Key (not the
# Secret Key — that's for OAuth flows this app doesn't use, and would be
# exposed publicly if put in a VITE_ variable). Demo apps are capped at
# 50 requests/hour.
VITE_UNSPLASH_ACCESS_KEY=
